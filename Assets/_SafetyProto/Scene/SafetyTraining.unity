--- !u!114 &1708245727
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1708245725}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f6f98ab4061897149a39537037626549, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SafetyProto.UI.OnboardingController
  popupService: {fileID: 5455797637335201551}
  steps:
  - title: Bem-vindo ao Treinamento
    body: "Voc\xEA est\xE1 em um ambiente virtual de treinamento de seguran\xE7a
      para canteiro de obras. A experi\xEAncia simula situa\xE7\xF5es reais baseadas
      nas normas NR-18 e NR-35. Siga as instru\xE7\xF5es com aten\xE7\xE3o."
    actionButtonLabel: Continuar
    icon: {fileID: 21300000, guid: e700f7a0eba57f64f93a406ee67dff41, type: 3}
    highlightTarget: {fileID: 0}
    onStepConfirmed:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 8185551094889031479}
          m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
          m_MethodName: SetActive
          m_Mode: 6
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 1
          m_CallState: 2
  - title: "Intera\xE7\xE3o com as M\xE3os"
    body: "Este treinamento n\xE3o utiliza controles. Toda a intera\xE7\xE3o \xE9
      feita com as suas m\xE3os. Apoie os controles e use apenas os movimentos naturais
      das m\xE3os durante toda a experi\xEAncia."
    actionButtonLabel: Entendi
    icon: {fileID: 21300000, guid: 411d27a3e567bfd45a0459692ff62892, type: 3}
    highlightTarget: {fileID: 0}
    onStepConfirmed:
      m_PersistentCalls:
        m_Calls: []
  - title: "Interagindo com os Pain\xE9is"
    body: "Este painel que voc\xEA est\xE1 lendo agora \xE9 como as instru\xE7\xF5es
      aparecer\xE3o durante toda a experi\xEAncia. Para confirmar, toque diretamente
      no bot\xE3o com o dedo indicador ou aponte o raio da m\xE3o e selecione \xE0
      dist\xE2ncia."
    actionButtonLabel: "Entendi \u2014 funcionou!"
    icon: {fileID: 21300000, guid: 4c73403134d9eb3458d9c495a33c2c13, type: 3}
    highlightTarget: {fileID: 0}
    onStepConfirmed:
      m_PersistentCalls:
        m_Calls: []
  - title: Pegando Objetos
    body: "Para pegar um objeto, aproxime a m\xE3o dele e feche o punho. Para soltar,
      abra a m\xE3o. Os objetos respondem ao toque das suas m\xE3os."
    actionButtonLabel: Entendi
    icon: {fileID: 21300000, guid: 25c0d8702947c8949b6593f764399b5a, type: 3}
    highlightTarget: {fileID: 0}
    onStepConfirmed:
      m_PersistentCalls:
        m_Calls: []
  - title: "O que voc\xEA vai fazer"
    body: "A experi\xEAncia tem dois cen\xE1rios: no primeiro, voc\xEA selecionar\xE1
      os equipamentos de prote\xE7\xE3o individual corretos. No segundo, inspecionar\xE1
      um andaime antes de iniciar o trabalho em altura. Ao final, voc\xEA receber\xE1
      seu resultado."
    actionButtonLabel: "Come\xE7ar"
    icon: {fileID: 21300000, guid: 2b131a3b7c020d140ad75182bcb4f8de, type: 3}
    highlightTarget: {fileID: 0}
    onStepConfirmed:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 4610155724688692438}
          m_TargetAssemblyTypeName: SafetyProto.Gameplay.Feedback.AudioFeedbackManager,
            Assembly-CSharp
          m_MethodName: PlaySuccessClip
          m_Mode: 1
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  autoStartOnEnable: 0
  startDelayFrames: 10
  onOnboardingFinished:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 8185551094889031479}
        m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
        m_MethodName: SetActive
        m_Mode: 6
        m_Arguments:
          m_ObjectArgument: {fileID: 0}
          m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
          m_IntArgument: 0
          m_FloatArgument: 0
          m_StringArgument: 
          m_BoolArgument: 1
        m_CallState: 2
  rememberSeen: 0
