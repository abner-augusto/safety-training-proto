{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 52428800
  },
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "parsableStyle": false,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "compress": false,
    "topFilesLength": 5,
    "showLineNumbers": false,
    "truncateBase64": false,
    "copyToClipboard": false,
    "includeFullDirectoryStructure": false,
    "tokenCountTree": false,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100,
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 50
    }
  },
  "include": [
    "Assets/_SafetyProto/**/*.cs",
    "Assets/_SafetyProto/**/*.asmdef",
    "Tools/**/*.cs",
    "Tools/**/*.csproj"
  ],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "**/*.obj",
      "**/*.fbx",
      "**/*.unity",
      "**/*.asset",
      "**/*.prefab",
      "**/*.meta",
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.mp3",
      "**/*.wav",
      "**/*.mat",
      "**/*.shader",
      "Assets/_SafetyProto/Resources/Dashboard/**"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}