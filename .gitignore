# REPOMIX — ignore outputs, keep settings
# ============================================================
repomix-output.*

scene_dump_*.md

# ============================================================
# SENSITIVE / LARGE DATA
# ============================================================
/[Mm]emoryCaptures/
/[Rr]ecordings/
.env*
*.local

