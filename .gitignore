# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore


# core unity engine cache
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# sensitive or large data
/[Mm]emoryCaptures/
/[Rr]ecordings/

# platform-specific
*.apk
*.aab
*.unitypackage
*.app
*.ipa

# project files
ExportedObj/
.consulo/
.vs/
.gradle/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.DS_Store

# meta files from debug symbols
*.pidb.meta
*.pdb.meta
*.mdb.meta

# crash/debug
sysinfo.txt
crashlytics-build.properties

# asset store / editor tools
/[Aa]ssets/AssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*

# addressables / streaming assets
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/**/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/**/*

# rider / ide config
.idea/
*.iml

# meta xr sdk generated artifacts
/[Aa]ssets/Oculus/
/[Aa]ssets/Meta/
/[Pp]roject[Ss]ettings/XRSettings.asset

# unity sample assets
/[Aa]ssets/[Ss]amples/

# ignore XR package noise
/[Aa]ssets/XR/Tests/
/[Aa]ssets/XR/Samples/
/[Aa]ssets/XR/Examples/

# ignore TextMesh Pro noise
/[Aa]ssets/TextMesh Pro/Examples*/
/[Aa]ssets/TextMesh Pro/Fonts/
/[Aa]ssets/TextMesh Pro/Resources/Font Assets/

# local dev / build cache
obj/
bin/
Builds*/
BuildCache/

# exclude .envs or config used in local testing
.env*
*.local

# logs / crash dumps
*.log
*.dmp

# temp scenes / backup autosaves
*.bak
*.backup
*.tmp
*.utmp
repomix-output.txt
/Assets/Dark UI
/Assets/TextMesh Pro
/Assets/TutorialInfo
Assets/_SafetyProto/Scripts/repomix-output.txt.meta
packages-microsoft-prod.deb
*.json
